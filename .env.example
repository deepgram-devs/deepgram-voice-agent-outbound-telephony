# ──────────────────────────────────────────────────────────────
# Outbound Telephony Voice Agent - Environment Variables
# ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# DEEPGRAM_API_KEY is required. Twilio credentials are required
# for placing outbound calls.
# See docs/LOCAL_DEVELOPMENT.md for the full setup guide.
# ──────────────────────────────────────────────────────────────

# Required - get a free key at https://console.deepgram.com
DEEPGRAM_API_KEY=

# Server settings (defaults shown)
# SERVER_HOST=0.0.0.0
# SERVER_PORT=8080

# Public URL where Twilio can reach this server. Required for outbound calls
# because Twilio needs to open a WebSocket back to stream audio.
# Set automatically by `python setup.py`, or manually if using a tunnel
# (ngrok, zrok) instead of the setup wizard.
# SERVER_EXTERNAL_URL=

# Voice agent model settings (defaults shown)
# LLM_MODEL=gpt-4o-mini
# LLM_PROVIDER=open_ai
# VOICE_MODEL=aura-2-thalia-en
# TTS_PROVIDER=deepgram
#
# For Fly.io deployments: edit these values, then run `python setup.py`
# and select "Redeploy" to sync changes to your deployed app.

# --- Twilio (required for placing outbound calls) ---
# TWILIO_ACCOUNT_SID=ACxxxxx
# TWILIO_AUTH_TOKEN=xxxxx
# TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# --- Security ---
# Endpoint secret for authenticating POST /make-call requests.
# Auto-generated by setup.py, or set your own.
# ENDPOINT_SECRET=
